{
  "name": "ai-review",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "bin": {
    "air": "./cli/air"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:build:install": "bash ./cli/build-install-macos.sh",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "electron:tsc": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:1420 && pnpm electron:tsc && cd core && cargo build -p core-sidecar -p core-launcher && cd .. && electron dist-electron/main.js\"",
    "electron:build": "tsc && vite build && pnpm electron:tsc && cd core && cargo build --release -p core-sidecar -p core-launcher && cd .. && electron-builder"
  },
  "dependencies": {
    "@catppuccin/highlightjs": "^1.0.1",
    "@fontsource/geist": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.7",
    "@types/hast": "^3.0.4",
    "highlight.js": "^11.11.1",
    "react": "^19.2.5",
    "react-diff-view": "^3.3.3",
    "react-dom": "^19.2.5",
    "rehype-react": "^8.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unidiff": "^1.0.4",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "hast-util-to-html": "^9.0.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.13",
    "rehype-stringify": "^10.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vfile": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.5"
  }
}
